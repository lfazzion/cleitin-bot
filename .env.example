# ── Rails Core ────────────────────────────────────────────────────────────────
SECRET_KEY_BASE=

# ── Discord Bot ──────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_ADMIN_CHANNEL_ID=                   # Canal para alertas de scraping e saúde do sistema
DISCORD_DIGEST_CHANNEL_ID=                  # Canal para digests semanais e de sexta

# ── LLM (Gemini / OpenRouter) ────────────────────────────────────────────────
GOOGLE_AI_API_KEY=                           # Google AI Studio (Gemini Flash, Gemma, Imagen)
OPENROUTER_API_KEY=                          # OpenRouter (Claude, Gemma 27B) — opcional

# ── APIs Externas (Catálogos) ────────────────────────────────────────────────
TMDB_API_KEY=                                # The Movie Database (read access token)
IGDB_CLIENT_ID=                              # Twitch/IGDB — client ID
IGDB_CLIENT_SECRET=                          # Twitch/IGDB — client secret
RAWG_API_KEY=                                # RAWG — video games database

# ── Scraping ─────────────────────────────────────────────────────────────────
CHROME_HOST=chrome                           # hostname do container Chrome no docker network
CHROME_PORT=9222                             # porta DevTools do Chrome headless
CHROME_BIN=                                  # caminho binário Chrome local (apenas dev sem Docker)
USE_NODRIVER=false                           # true = usar Python nodriver em vez de Ferrum
USE_PROXY=false                              # true = ativar proxy residencial
SCRAPING_PROXY=                              # URL do proxy (ex: socks5://user:pass@host:port)

# ── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_IMAGE_GENERATION=false                # true = ativar geração de imagens via Gemini Imagen 3
ENABLE_PAGE_FETCH=false                      # true = registrar PageFetchTool no chatbot (fetch + Chrome render)
ALERT_THROTTLE_ENABLED=true                  # true = limitar alertas (max 10/hora por tipo)
BACKUP_RETENTION_DAYS=7                      # dias de retenção dos backups do SQLite

# ── Web Search (SearXNG) ─────────────────────────────────────────────────────
SEARXNG_SECRET_KEY=                          # gerar com: openssl rand -hex 32
SEARXNG_URL=http://searxng:8080/search
